---
import TeamProfile from "../components/TeamProfile.astro";
import TeamPageBackground from "../components/TeamPageBackground.astro";
import { teamMembers } from "../data/team";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Our Team" description="Meet the team building Oiva.">
  <section class="team-page" aria-labelledby="team-title">
    <TeamPageBackground />
    <div class="team-page__inner">
      <h1 id="team-title">Our Team</h1>

      <div class="team-grid">
        {teamMembers.map((member) => <TeamProfile member={member} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-page {
    margin: 0;
    min-height: calc(100vh - var(--header-height));
    overflow: hidden;
    padding: var(--space-section) var(--space-page);
    position: relative;
    text-align: center;
  }

  .team-page__inner {
    margin: 0 auto;
    max-width: var(--container-wide);
    position: relative;
    z-index: 1;
  }

  h1 {
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-2xl);
  }

  .team-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  :global(.site-page:has(.team-page) .site-footer) {
    margin-top: 0;
  }

  @media (max-width: 980px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .team-page {
      padding-block: var(--space-2xl);
    }

    h1 {
      margin-bottom: var(--space-xl);
    }

    .team-grid {
      gap: var(--space-md);
      grid-template-columns: 1fr;
    }
  }
</style>
