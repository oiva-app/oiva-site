---
import BaseLayout from "../layouts/BaseLayout.astro";
import Callout from "../components/Callout.astro";
import DiagramFrame from "../components/DiagramFrame.astro";
import FigureCard from "../components/FigureCard.astro";
import WideFigure from "../components/WideFigure.astro";
import DottedGrid from "../components/motifs/DottedGrid.astro";
import LandscapeBands from "../components/motifs/LandscapeBands.astro";
import TopographicLines from "../components/motifs/TopographicLines.astro";
import { withBase } from "../lib/urls";

const paletteGroups = [
  {
    title: "Backgrounds",
    tokens: [
      ["bg", "--color-bg"],
      ["soft", "--color-bg-soft"],
      ["wash", "--color-bg-wash"],
    ],
  },
  {
    title: "Surfaces",
    tokens: [
      ["surface", "--color-surface"],
      ["muted", "--color-surface-muted"],
      ["raised", "--color-surface-raised"],
    ],
  },
  {
    title: "Text",
    tokens: [
      ["text", "--color-text"],
      ["muted", "--color-text-muted"],
      ["subtle", "--color-text-subtle"],
    ],
  },
  {
    title: "Accents",
    tokens: [
      ["primary", "--color-primary"],
      ["yellow", "--color-accent-yellow"],
      ["blue", "--color-accent-blue"],
      ["green", "--color-accent-green"],
      ["coral", "--color-accent-coral"],
    ],
  },
];

const spacingTokens = [
  ["2xs", "--space-2xs"],
  ["xs", "--space-xs"],
  ["sm", "--space-sm"],
  ["md", "--space-md"],
  ["lg", "--space-lg"],
  ["xl", "--space-xl"],
  ["2xl", "--space-2xl"],
  ["3xl", "--space-3xl"],
];
---

<BaseLayout
  title="Oiva Style Guide"
  description="Foundational design-system checkpoint for Oiva's Astro site."
>
  <section class="style-guide-shell">
    <aside class="style-nav" aria-label="Style guide sections">
      <p>Style Guide</p>
      <a href="#overview">Overview</a>
      <a href="#color">Color</a>
      <a href="#typography">Typography</a>
      <a href="#spacing">Spacing</a>
      <a href="#components">Components</a>
      <a href="#motifs">Motifs</a>
      <a href="#layout">Layout</a>
      <a href="#dark-mode">Dark Mode</a>
    </aside>

    <div class="style-guide-content">
      <section class="style-hero" id="overview">
        <p class="eyebrow">Overview</p>
        <h1>Oiva Style Guide</h1>
        <p>
          A working checkpoint for a technical atlas: warm paper surfaces, deep green text,
          restrained diagrams, and documentation-first reading patterns.
        </p>
      </section>

      <section class="guide-section" id="color">
        <div class="section-heading">
          <p class="eyebrow">Foundation</p>
          <h2>Color Palette</h2>
        </div>

        <div class="palette-grid">
          {paletteGroups.map((group) => (
            <article>
              <h3>{group.title}</h3>
              <div class="swatch-row">
                {group.tokens.map(([label, token]) => (
                  <div class="swatch-item">
                    <span class="swatch" style={`--swatch: var(${token})`}></span>
                    <strong>{label}</strong>
                    <code>{token}</code>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="guide-section" id="typography">
        <div class="section-heading">
          <p class="eyebrow">Foundation</p>
          <h2>Typography</h2>
        </div>

        <div class="type-specimen">
          <div>
            <p>
              H1 and H2 use the display serif for a calm, authoritative reading voice.
              Body, navigation, sidebars, captions, and UI use the sans stack.
            </p>
          </div>
          <div class="type-list">
            <div>
              <span>H1</span>
              <strong class="type-h1">Evidence-backed incident investigation</strong>
              <code>--text-3xl / display</code>
            </div>
            <div>
              <span>H2</span>
              <strong class="type-h2">A field guide for system behavior</strong>
              <code>--text-2xl / display</code>
            </div>
            <div>
              <span>H3</span>
              <strong class="type-h3">Correlation across telemetry and code</strong>
              <code>--text-lg / sans</code>
            </div>
            <div>
              <span>Body</span>
              <p>Oiva helps teams connect production signals with codebase context and team workflows.</p>
              <code>--text-base / sans</code>
            </div>
            <div>
              <span>Caption</span>
              <p class="caption">Diagram caption text stays compact, scannable, and quiet.</p>
              <code>--text-sm / sans</code>
            </div>
          </div>
        </div>
      </section>

      <section class="guide-section" id="spacing">
        <div class="section-heading">
          <p class="eyebrow">Foundation</p>
          <h2>Spacing</h2>
        </div>

        <div class="spacing-list">
          {spacingTokens.map(([label, token]) => (
            <div>
              <span>{label}</span>
              <div class="spacing-track">
                <i style={`width: var(${token})`}></i>
              </div>
              <code>{token}</code>
            </div>
          ))}
        </div>
      </section>

      <section class="guide-section" id="components">
        <div class="section-heading">
          <p class="eyebrow">Components</p>
          <h2>Buttons, Cards, Callouts, Code</h2>
        </div>

        <div class="component-stack">
          <div class="sample-row">
            <a class="button button-primary" href={withBase("/case-study/")}>Primary</a>
            <a class="button button-secondary" href={withBase("/getting-started/")}>Secondary</a>
            <a class="button button-text" href={withBase("/team/")}>Text link -></a>
          </div>

          <div class="card-grid">
            <article class="card">
              <span class="sample-icon">01</span>
              <h3>Default card</h3>
              <p>Used for grouped related content without heavy visual weight.</p>
            </article>
            <article class="card card-raised">
              <span class="sample-icon">02</span>
              <h3>Raised card</h3>
              <p>Used when a component needs slightly more emphasis.</p>
            </article>
            <article class="card card-outline">
              <span class="sample-icon">03</span>
              <h3>Outline card</h3>
              <p>Used for lower-emphasis grouping and layout examples.</p>
            </article>
          </div>

          <div class="callout-grid">
            <Callout title="Insight">
              <p>Highlights a useful observation from the system design.</p>
            </Callout>
            <Callout title="Decision" variant="decision">
              <p>Records a tradeoff or design choice worth preserving.</p>
            </Callout>
            <Callout title="Warning" variant="warning">
              <p>Flags a risk, limitation, or important implementation note.</p>
            </Callout>
            <Callout title="Technical note" variant="note">
              <p>Adds context without interrupting the reading flow.</p>
            </Callout>
          </div>

          <pre><code>{`async function investigate(incidentId) {
  const signals = await oiva.signals.fetch(incidentId);
  const analysis = await oiva.rootCause.analyze(signals);
  return analysis.recommendations;
}`}</code></pre>
        </div>
      </section>

      <section class="guide-section" id="figures">
        <div class="section-heading">
          <p class="eyebrow">Content</p>
          <h2>Figures and Diagrams</h2>
        </div>

        <div class="diagram-grid">
          <DiagramFrame
            title="Workflow diagram"
            caption="Workflow diagrams use short labels, thin strokes, and muted color."
            motif="topographic"
          >
            <div class="workflow-diagram" aria-label="Workflow diagram example">
              <span>Alert</span>
              <i></i>
              <span>Signals</span>
              <i></i>
              <span>Report</span>
            </div>
          </DiagramFrame>

          <DiagramFrame
            title="Infrastructure diagram"
            caption="Infrastructure diagrams stay grid-aligned and avoid ambiguous arrows."
            variant="infrastructure"
            motif="dots"
          >
            <div class="system-diagram" aria-label="System diagram example">
              <span>Sources</span>
              <span>Detection</span>
              <span>Diagnosis</span>
              <b></b>
              <b></b>
              <b></b>
            </div>
          </DiagramFrame>
        </div>

        <WideFigure>
          <FigureCard
            title="Wide figure"
            eyebrow="Breakout"
            caption="Wide figures are capped at the wide-content token and can hold larger diagrams."
            sourceLabel="Design system"
          >
            <div class="wide-demo">Wide diagram region</div>
          </FigureCard>
        </WideFigure>
      </section>

      <section class="guide-section" id="motifs">
        <div class="section-heading">
          <p class="eyebrow">Visual System</p>
          <h2>Decorative Motifs</h2>
        </div>

        <div class="motif-grid">
          <article class="motif-demo-card">
            <TopographicLines position="fill" density="medium" />
            <div>
              <h3>Topographic lines</h3>
              <p>Low-contrast contour lines for section atmosphere and diagram frames.</p>
            </div>
          </article>

          <article class="motif-demo-card">
            <DottedGrid position="fill" density="medium" />
            <div>
              <h3>Dotted grids</h3>
              <p>Technical structure for diagrams and quiet background zones.</p>
            </div>
          </article>

          <article class="motif-demo-card motif-demo-wide">
            <LandscapeBands position="bottom" tone="muted" />
            <div>
              <h3>Landscape bands</h3>
              <p>Layered Nordic-inspired transitions for heroes and major section breaks.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="guide-section" id="layout">
        <div class="section-heading">
          <p class="eyebrow">Patterns</p>
          <h2>Sidebar and Layout Examples</h2>
        </div>

        <div class="layout-demo">
          <nav class="sidebar-demo" aria-label="Sidebar example">
            <p>Case Study</p>
            <a aria-current="page" href="#layout">Overview</a>
            <a href="#layout">Problem domain</a>
            <a href="#layout">Design decisions</a>
            <a href="#layout">Infrastructure</a>
          </nav>
          <article class="reading-demo">
            <p class="eyebrow">Reading Column</p>
            <h3>Left sidebar with centered narrative content</h3>
            <p>
              Long-form pages prioritize a stable navigation rail and a comfortable reading
              column. Diagrams can break out to wider frames without changing page routing.
            </p>
            <FigureCard title="Inline figure" caption="Reusable cards keep figure title and caption treatment consistent.">
              <div class="wide-demo">Wide diagram region</div>
            </FigureCard>
          </article>
        </div>
      </section>

      <section class="guide-section" id="dark-mode">
        <div class="section-heading">
          <p class="eyebrow">Validation</p>
          <h2>Light and Dark Mode</h2>
        </div>

        <div class="theme-validation">
          <article class="theme-card" data-theme="light">
            <p class="eyebrow">Light</p>
            <h3>Paper atlas</h3>
            <p>Warm surfaces, dark green text, and quiet accent colors.</p>
            <a class="button button-primary" href="#dark-mode">Primary</a>
          </article>
          <article class="theme-card" data-theme="dark">
            <p class="eyebrow">Dark</p>
            <h3>Deep field guide</h3>
            <p>Deep teal surfaces with warm yellow as the primary action color.</p>
            <a class="button button-primary" href="#dark-mode">Primary</a>
          </article>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .style-guide-shell {
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: minmax(12rem, 14rem) minmax(0, 1fr);
    margin: 0 auto;
    max-width: var(--container-page);
    padding: var(--space-2xl) var(--space-page) 0;
  }

  .style-nav {
    align-self: start;
    background: color-mix(in srgb, var(--color-surface) 82%, transparent);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    display: grid;
    gap: var(--space-2xs);
    padding: var(--space-md);
    position: sticky;
    top: calc(var(--header-height) + var(--space-lg));
  }

  .style-nav p {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 800;
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
  }

  .style-nav a {
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 650;
    line-height: var(--leading-ui);
    padding: 0.45rem 0.6rem;
    text-decoration: none;
  }

  .style-nav a:hover {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  .style-guide-content {
    min-width: 0;
  }

  .style-hero {
    border-bottom: 1px solid var(--border-subtle);
    min-height: 18rem;
    padding: var(--space-lg) 0 var(--space-2xl);
    position: relative;
  }

  .style-hero::after {
    background:
      radial-gradient(circle at 78% 28%, var(--color-accent-yellow) 0 2.2rem, transparent 2.25rem),
      linear-gradient(150deg, transparent 0 38%, color-mix(in srgb, var(--color-accent-blue) 32%, transparent) 38% 62%, transparent 62%),
      linear-gradient(160deg, transparent 0 48%, color-mix(in srgb, var(--color-accent-green) 34%, transparent) 48% 74%, transparent 74%);
    border-radius: var(--radius-xl);
    content: "";
    inset: 0 0 0 auto;
    opacity: 0.8;
    pointer-events: none;
    position: absolute;
    width: min(38rem, 48%);
  }

  .style-hero h1 {
    font-size: var(--text-3xl);
    margin: 0;
    max-width: 12ch;
    position: relative;
    z-index: 1;
  }

  .style-hero p:not(.eyebrow) {
    color: var(--color-text-muted);
    font-size: var(--text-md);
    line-height: 1.65;
    margin: var(--space-md) 0 0;
    max-width: 52ch;
    position: relative;
    z-index: 1;
  }

  .guide-section {
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-xl) 0;
  }

  .section-heading {
    margin-bottom: var(--space-lg);
  }

  .section-heading h2 {
    font-size: var(--text-xl);
    margin: 0;
  }

  .palette-grid,
  .component-stack {
    display: grid;
    gap: var(--space-lg);
  }

  .palette-grid article {
    display: grid;
    gap: var(--space-sm);
  }

  .palette-grid h3,
  .card h3,
  .reading-demo h3,
  .theme-card h3 {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    margin: 0;
  }

  .swatch-row {
    display: grid;
    gap: var(--space-sm);
    grid-template-columns: repeat(auto-fit, minmax(7.5rem, 1fr));
  }

  .swatch-item {
    display: grid;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .swatch {
    background: var(--swatch);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    display: block;
    height: 4rem;
  }

  .swatch-item strong,
  .spacing-list span,
  .type-list span {
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .swatch-item code,
  .spacing-list code,
  .type-list code {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
  }

  .type-specimen {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: minmax(12rem, 0.35fr) 1fr;
  }

  .type-specimen > div:first-child {
    border-right: 1px solid var(--border-subtle);
    color: var(--color-text-muted);
    padding-right: var(--space-lg);
  }

  .type-list {
    display: grid;
  }

  .type-list > div {
    align-items: baseline;
    border-bottom: 1px solid var(--border-subtle);
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 3rem minmax(0, 1fr) 12rem;
    padding: var(--space-sm) 0;
  }

  .type-list p {
    margin: 0;
  }

  .type-h1,
  .type-h2 {
    font-family: var(--font-display);
    line-height: var(--leading-heading);
  }

  .type-h1 {
    font-size: var(--text-2xl);
  }

  .type-h2 {
    font-size: var(--text-xl);
  }

  .type-h3 {
    font-size: var(--text-lg);
  }

  .caption {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .spacing-list {
    display: grid;
    gap: var(--space-sm);
  }

  .spacing-list > div {
    align-items: center;
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 3rem 1fr 9rem;
  }

  .spacing-track {
    background: var(--color-surface-muted);
    border-radius: var(--radius-xs);
    height: 0.75rem;
  }

  .spacing-track i {
    background: var(--color-primary);
    border-radius: inherit;
    display: block;
    height: 100%;
  }

  .sample-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .card-grid,
  .callout-grid,
  .diagram-grid,
  .motif-grid,
  .theme-validation {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .callout-grid,
  .diagram-grid,
  .motif-grid,
  .theme-validation {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .motif-demo-card {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    min-height: 13rem;
    overflow: hidden;
    padding: var(--space-xl);
    position: relative;
  }

  .motif-demo-card > div {
    max-width: 32rem;
    position: relative;
    z-index: 1;
  }

  .motif-demo-card h3 {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    margin: 0 0 var(--space-xs);
  }

  .motif-demo-card p {
    color: var(--color-text-muted);
    line-height: var(--leading-ui);
    margin: 0;
  }

  .motif-demo-wide {
    grid-column: 1 / -1;
  }

  .sample-icon {
    align-items: center;
    background: var(--color-primary-soft);
    border-radius: 999px;
    color: var(--color-primary);
    display: inline-flex;
    font-size: var(--text-xs);
    font-weight: 800;
    height: 2.25rem;
    justify-content: center;
    margin-bottom: var(--space-md);
    width: 2.25rem;
  }

  .card p {
    color: var(--color-text-muted);
    line-height: var(--leading-ui);
    margin: var(--space-xs) 0 0;
  }

  .workflow-diagram,
  .system-diagram {
    align-items: center;
    background: color-mix(in srgb, var(--color-bg-soft) 64%, var(--color-surface));
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    display: grid;
    min-height: 10rem;
    padding: var(--space-lg);
  }

  .workflow-diagram {
    grid-template-columns: 1fr 2rem 1fr 2rem 1fr;
  }

  .workflow-diagram span,
  .system-diagram span {
    background: var(--color-surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 700;
    padding: var(--space-sm);
    text-align: center;
  }

  .workflow-diagram i {
    background: var(--color-accent-yellow);
    display: block;
    height: 2px;
  }

  .system-diagram {
    gap: var(--space-sm);
    grid-template-columns: repeat(3, 1fr);
  }

  .system-diagram b {
    background: color-mix(in srgb, var(--color-primary-soft) 74%, transparent);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xs);
    display: block;
    height: 3rem;
  }

  .layout-demo {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: minmax(11rem, 14rem) minmax(0, 1fr);
    padding: var(--space-lg);
  }

  .sidebar-demo {
    border-right: 1px solid var(--border-subtle);
    display: grid;
    gap: var(--space-2xs);
    padding-right: var(--space-lg);
  }

  .sidebar-demo p {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 800;
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
  }

  .sidebar-demo a {
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 650;
    padding: var(--space-xs) var(--space-sm);
    text-decoration: none;
  }

  .sidebar-demo a[aria-current="page"],
  .sidebar-demo a:hover {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  .reading-demo p:not(.eyebrow) {
    color: var(--color-text-muted);
    max-width: var(--container-content);
  }

  .wide-demo {
    background:
      linear-gradient(90deg, transparent 0 18%, var(--border-subtle) 18% 18.3%, transparent 18.3% 100%),
      var(--color-surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    margin-top: var(--space-lg);
    max-width: var(--container-wide-content);
    padding: var(--space-xl);
    text-align: center;
  }

  .theme-card {
    background: var(--color-bg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    padding: var(--space-xl);
  }

  .theme-card p:not(.eyebrow) {
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .style-guide-shell,
    .type-specimen,
    .layout-demo {
      grid-template-columns: 1fr;
    }

    .style-nav {
      position: static;
    }

    .style-hero::after {
      opacity: 0.35;
      width: 100%;
    }

    .type-specimen > div:first-child,
    .sidebar-demo {
      border-right: 0;
      padding-right: 0;
    }
  }

  @media (max-width: 720px) {
    .card-grid,
    .callout-grid,
    .diagram-grid,
    .motif-grid,
    .theme-validation,
    .type-list > div,
    .spacing-list > div {
      grid-template-columns: 1fr;
    }

    .motif-demo-wide {
      grid-column: auto;
    }

    .workflow-diagram {
      gap: var(--space-sm);
      grid-template-columns: 1fr;
    }

    .workflow-diagram i {
      height: 1.5rem;
      justify-self: center;
      width: 2px;
    }
  }
</style>
