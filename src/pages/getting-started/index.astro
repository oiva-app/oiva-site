---
import { getEntry, render } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import { toSinglePageSidebarPages } from "../../lib/content";

const entry = await getEntry("gettingStarted", "index");

if (!entry) {
  throw new Error("Missing getting started index content entry.");
}

const { Content, headings } = await render(entry);
const pages = toSinglePageSidebarPages("gettingStarted", headings);
const currentPageId = pages[0]?.id ?? entry.id;
---

<ContentPageLayout
  section="gettingStarted"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={currentPageId}
  pages={pages}
>
  <Content />
</ContentPageLayout>
