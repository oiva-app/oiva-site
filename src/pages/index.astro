---
import GeneralOivaWorkflow from "../components/GeneralOivaWorkflow.astro";
import HomeHero from "../components/HomeHero.astro";
import DemoVideo from "../components/DemoVideo.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { heroSubtext } from "../data/home";
import { withBase } from "../lib/urls";
---

<BaseLayout title="Oiva" bareTitle description={heroSubtext}>
  <HomeHero />

  <section class="home-section home-how-it-works" aria-labelledby="home-how-title">
    <div class="home-section__inner">
      <p class="eyebrow">Workflow</p>
      <h2 id="home-how-title">How Oiva Works</h2>
      <p class="home-section__lead">From an alert to an evidence-backed incident report.</p>
      <GeneralOivaWorkflow />
    </div>
  </section>

  <section class="home-section home-demo" aria-labelledby="home-demo-title">
    <div class="home-section__inner">
      <p class="eyebrow">Demo</p>
      <h2 id="home-demo-title">See Oiva In Action</h2>
      <p class="home-section__lead">A production alert arrives and starts an investigation workflow.</p>
      <div class="home-demo__media">
        <DemoVideo />
      </div>
    </div>
  </section>

  <section class="home-section home-next-steps" aria-labelledby="home-next-title">
    <div class="home-section__inner">
      <h2 id="home-next-title">Next Steps</h2>
      <div class="button-row home-next-steps__links">
        <a class="button button-primary" href={withBase("/case-study/")}>Case Study</a>
        <a class="button button-secondary" href={withBase("/get-started/manual-setup/")}>Get Started</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-section {
    padding: var(--space-section) var(--space-page) 0;
  }

  .home-section__inner {
    margin: 0 auto;
    max-width: var(--container-wide);
  }

  .home-demo h2,
  .home-how-it-works h2,
  .home-next-steps h2 {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    letter-spacing: 0;
    margin: 0;
  }

  .home-section__lead {
    color: var(--color-muted);
    font-size: var(--text-md);
    line-height: 1.6;
    margin: var(--space-md) 0 0;
    max-width: 38rem;
  }

  .home-demo__media {
    margin: var(--space-xl) auto 0;
    max-width: 880px;
    min-width: 0;
  }

  .home-next-steps {
    padding-bottom: var(--space-section);
    text-align: center;
  }

  .home-next-steps__links {
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 620px) {
    .home-next-steps__links {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
