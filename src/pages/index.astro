---
import oivaBearLogo from "../assets/logo/oiva_bear_green.svg";
import HomeHeroAtlasBackground from "../components/HomeHeroAtlasBackground.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "A self-hosted incident investigation agent that turns production alerts into evidence-backed investigation reports";
---

<BaseLayout title="Oiva" bareTitle description={description}>
  <section class="home-hero" aria-labelledby="home-title">
    <HomeHeroAtlasBackground />
    <div class="home-hero__inner">
      <div class="home-hero__visual" aria-hidden="true">
        <div class="home-hero__logo">
          <img src={oivaBearLogo.src} alt="" loading="eager" decoding="async" />
        </div>
      </div>
      <div class="home-hero__content">
        <h1 id="home-title">Oiva</h1>
        <p class="home-hero__summary">{description}</p>
        <div class="button-row home-hero__actions" aria-label="Primary links">
          <a class="button button-primary" href="/case-study/overview/">Case Study</a>
          <a class="button button-secondary" href="/getting-started/overview/">Getting Started</a>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-demo" aria-labelledby="home-demo-title">
    <div class="home-section__inner home-demo__inner">
      <div class="home-demo__copy">
        <p class="eyebrow">Demo</p>
        <h2 id="home-demo-title">See Oiva receive an alert</h2>
        <p>A production alert arrives in Slack and starts an investigation workflow.</p>
      </div>
      <div class="home-demo__media" aria-label="Slack alert demo video placeholder">
        <!-- TODO: Replace this placeholder with /media/oiva-slack-alert-demo.mp4 when the demo video is available. -->
        <div class="home-demo__placeholder">
          <span>Slack alert demo video placeholder</span>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-how-it-works" aria-labelledby="home-how-title">
    <div class="home-section__inner">
      <p class="eyebrow">Workflow</p>
      <h2 id="home-how-title">How Oiva Works</h2>
      <div class="home-steps">
        <article class="home-step">
          <span class="home-step__number">1</span>
          <h3>Alert received</h3>
          <p>A production alert arrives from Slack or the alerting workflow.</p>
        </article>
        <article class="home-step">
          <span class="home-step__number">2</span>
          <h3>Investigation launched</h3>
          <p>Oiva gathers observability data, codebase context, and delivery workflow evidence.</p>
        </article>
        <article class="home-step">
          <span class="home-step__number">3</span>
          <h3>Report delivered</h3>
          <p>Oiva produces an evidence-backed investigation report for the team.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section home-next-steps" aria-labelledby="home-next-title">
    <div class="home-section__inner">
      <h2 id="home-next-title">Next steps</h2>
      <div class="button-row home-next-steps__links">
        <a class="button button-primary" href="/case-study/overview/">Case Study</a>
        <a class="button button-secondary" href="/getting-started/overview/">Getting Started</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    align-items: flex-start;
    contain: paint;
    display: flex;
    isolation: isolate;
    margin: 0;
    max-width: none;
    min-height: calc(100svh - var(--header-height));
    overflow: clip;
    padding: clamp(var(--space-2xl), 6vw, var(--space-4xl)) var(--space-page) var(--space-3xl);
    position: relative;
  }

  .home-hero__inner {
    align-items: center;
    display: grid;
    gap: var(--space-3xl);
    grid-template-columns: minmax(18rem, 0.95fr) minmax(0, 1.05fr);
    margin: 0 auto;
    max-width: var(--container-wide);
    min-height: calc(100svh - var(--header-height) - clamp(var(--space-2xl), 6vw, var(--space-4xl)) - var(--space-3xl));
    position: relative;
    width: 100%;
    z-index: 1;
  }

  .home-hero__visual {
    grid-column: 1;
    grid-row: 1;
    min-height: clamp(18rem, 44vw, 34rem);
    min-width: 0;
    position: relative;
  }

  .home-hero__logo {
    align-items: center;
    display: flex;
    justify-content: center;
    inset: 0;
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .home-hero__logo img {
    display: block;
    max-height: clamp(14rem, 38vw, 28rem);
    object-fit: contain;
    width: min(100%, 30rem);
  }

  .home-hero__content {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
    padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
  }

  .home-hero h1 {
    font-size: clamp(4rem, 14vw, 9rem);
    letter-spacing: 0;
    line-height: 0.9;
    margin: 0;
  }

  .home-hero__summary {
    color: var(--color-muted);
    font-size: clamp(var(--text-md), 2vw, var(--text-lg));
    line-height: 1.55;
    margin: var(--space-lg) 0 var(--space-xl);
    max-width: 44rem;
  }

  .home-hero__actions .button {
    background-clip: padding-box;
  }

  .home-hero__actions .button-primary {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .home-hero__actions .button-secondary {
    background: var(--color-surface-raised);
    border-color: var(--border-strong);
  }

  .home-section {
    padding: var(--space-section) var(--space-page) 0;
  }

  .home-section__inner {
    margin: 0 auto;
    max-width: var(--container-wide);
  }

  .home-demo__inner {
    align-items: center;
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: minmax(0, 0.85fr) minmax(18rem, 1.15fr);
  }

  .home-demo h2,
  .home-how-it-works h2,
  .home-next-steps h2 {
    font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));
    letter-spacing: 0;
    margin: 0;
  }

  .home-demo__copy p:not(.eyebrow) {
    color: var(--color-muted);
    font-size: var(--text-md);
    line-height: 1.6;
    margin: var(--space-md) 0 0;
    max-width: 38rem;
  }

  .home-demo__media {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    min-width: 0;
    overflow: hidden;
    padding-top: 2.25rem;
    position: relative;
  }

  .home-demo__media::before {
    background:
      radial-gradient(circle, var(--color-accent-coral) 0 0.28rem, transparent 0.3rem) 1rem 50% / 0.7rem 0.7rem no-repeat,
      radial-gradient(circle, var(--color-accent-yellow) 0 0.28rem, transparent 0.3rem) 2rem 50% / 0.7rem 0.7rem no-repeat,
      radial-gradient(circle, var(--color-accent-green) 0 0.28rem, transparent 0.3rem) 3rem 50% / 0.7rem 0.7rem no-repeat,
      linear-gradient(180deg, var(--color-surface-raised), var(--color-surface));
    border-bottom: 1px solid var(--color-border);
    content: "";
    height: 2.25rem;
    inset: 0 0 auto;
    position: absolute;
  }

  .home-demo__placeholder {
    align-items: center;
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-surface) 74%, transparent), color-mix(in srgb, var(--color-bg-soft) 66%, transparent)),
      var(--color-card);
    border: 0;
    border-radius: 0;
    color: var(--color-muted);
    display: flex;
    justify-content: center;
    padding: var(--space-lg);
    text-align: center;
  }

  .home-demo__placeholder span {
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: var(--leading-ui);
  }

  .home-steps {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: var(--space-xl);
  }

  .home-step {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-lg);
  }

  .home-step__number {
    align-items: center;
    background: var(--color-accent-strong);
    border-radius: 999px;
    color: var(--color-background);
    display: inline-flex;
    font-size: var(--text-xs);
    font-weight: 800;
    height: 1.75rem;
    justify-content: center;
    line-height: 1;
    margin-bottom: var(--space-md);
    width: 1.75rem;
  }

  .home-step h3 {
    font-size: var(--text-md);
    margin: 0;
  }

  .home-step p {
    color: var(--color-muted);
    line-height: 1.6;
    margin: var(--space-sm) 0 0;
  }

  .home-next-steps {
    padding-bottom: var(--space-section);
    text-align: center;
  }

  .home-next-steps__links {
    justify-content: center;
    margin-top: var(--space-lg);
  }

  @media (max-width: 920px) {
    .home-hero__inner,
    .home-demo__inner {
      grid-template-columns: 1fr;
    }

    .home-hero {
      gap: var(--space-2xl);
      min-height: auto;
      padding-block: var(--space-2xl) var(--space-3xl);
    }

    .home-hero__inner {
      gap: var(--space-xl);
      min-height: auto;
    }

    .home-hero__visual {
      grid-column: 1;
      grid-row: 1;
      min-height: auto;
    }

    .home-hero__content {
      grid-column: 1;
      grid-row: 2;
      padding: var(--space-lg);
    }

    .home-hero__logo {
      justify-content: flex-start;
    }

    .home-hero__logo img {
      max-height: clamp(12rem, 34vw, 18rem);
      width: min(100%, 22rem);
    }

    .home-steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .home-hero {
      padding-block: var(--space-xl) var(--space-2xl);
    }

    .home-hero__inner {
      gap: var(--space-lg);
    }

    .home-hero__logo img {
      max-height: clamp(11rem, 48vw, 16rem);
      width: min(100%, 18rem);
    }

    .home-hero__actions,
    .home-next-steps__links {
      align-items: stretch;
      flex-direction: column;
    }
  }
</style>
