---
import { getEntry, render } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import { toSinglePageSidebarPages } from "../../lib/content";

const entry = await getEntry("caseStudy", "index");

if (!entry) {
  throw new Error("Missing case study index content entry.");
}

const { Content, headings } = await render(entry);
const pages = toSinglePageSidebarPages("caseStudy", headings);
const currentPageId = pages[0]?.id ?? entry.id;
---

<ContentPageLayout
  section="caseStudy"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={currentPageId}
  pages={pages}
>
  <Content />
</ContentPageLayout>
