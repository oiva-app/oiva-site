---
import { render, type CollectionEntry } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import {
  getSectionEntries,
  mapSectionPages,
  toHeadingLinks,
  type SectionPage,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getSectionEntries("caseStudy");
  const pages = mapSectionPages("caseStudy", entries);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, pages },
  }));
}

type Props = {
  entry: CollectionEntry<"caseStudy">;
  pages: SectionPage[];
};

const { entry, pages } = Astro.props;
const { Content, headings } = await render(entry);
const pagesWithCurrentHeadings = pages.map((page) => page.id === entry.id
  ? { ...page, headings: toHeadingLinks(headings) }
  : page);
---

<ContentPageLayout
  section="caseStudy"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={entry.id}
  pages={pagesWithCurrentHeadings}
>
  <Content />
</ContentPageLayout>
