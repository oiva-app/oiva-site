---
import { render, type CollectionEntry } from "astro:content";
import ContentPageLayout from "../../components/ContentPageLayout.astro";
import {
  getSectionEntries,
  mapSectionPagesWithHeadings,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getSectionEntries("caseStudy");

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, entries },
  }));
}

type Props = {
  entry: CollectionEntry<"caseStudy">;
  entries: CollectionEntry<"caseStudy">[];
};

const { entry, entries } = Astro.props;
const { Content } = await render(entry);
const pages = await mapSectionPagesWithHeadings("caseStudy", entries);
---

<ContentPageLayout
  section="caseStudy"
  title={entry.data.title}
  description={entry.data.description}
  currentPageId={entry.id}
  pages={pages}
>
  <Content />
</ContentPageLayout>
