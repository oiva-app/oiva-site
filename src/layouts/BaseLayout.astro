---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import type { HeadingLink, SectionKey, SectionPage } from "../lib/content";

type Props = {
  title?: string;
  description?: string;
  section?: SectionKey;
  sectionPages?: SectionPage[];
  currentPageId?: string;
  headings?: HeadingLink[];
};

const {
  title = "Oiva",
  description = "Oiva is an open-source, self-hosted service for AI-assisted incident investigation.",
  section,
  sectionPages = [],
  currentPageId,
  headings = [],
} = Astro.props;
const pageTitle = title === "Oiva" ? title : `${title} | Oiva`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        let storedTheme = null;

        try {
          const theme = localStorage.getItem("theme");
          storedTheme = theme === "dark" || theme === "light" ? theme : null;
        } catch {
          // Ignore unavailable storage.
        }

        document.documentElement.dataset.theme = storedTheme || getSystemTheme();
      })();
    </script>
  </head>
  <body>
    <Header
      section={section}
      sectionPages={sectionPages}
      currentPageId={currentPageId}
      headings={headings}
    />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
