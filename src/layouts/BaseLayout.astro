---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContentPageHillsBackground from "../components/ContentPageHillsBackground.astro";
import FigureModal from "../components/FigureModal.astro";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { SectionKey, SectionPage } from "../lib/content";
import { withBase } from "../lib/urls";

type Props = {
  title?: string;
  description?: string;
  bareTitle?: boolean;
  section?: SectionKey;
  sectionPages?: SectionPage[];
  currentPageId?: string;
};

const {
  title = "Oiva",
  description = "Oiva is an open-source, self-hosted service for AI-assisted incident investigation.",
  bareTitle = false,
  section,
  sectionPages = [],
  currentPageId,
} = Astro.props;
const pageTitle = bareTitle ? title : `${title} | Oiva`;
const hasContentPageBackground = section === "caseStudy" || section === "getStarted";
---

<html lang="en" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <slot name="head" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link
      rel="icon"
      type="image/svg+xml"
      href={withBase("/favicon-light.svg")}
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href={withBase("/favicon-dark.svg")}
      media="(prefers-color-scheme: dark)"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        const getSystemTheme = () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";

        let storedTheme = null;

        try {
          const theme = localStorage.getItem("theme");
          storedTheme = theme === "dark" || theme === "light" ? theme : null;
        } catch {
          // Ignore unavailable storage.
        }

        document.documentElement.dataset.theme = storedTheme || getSystemTheme();
      })();
    </script>
  </head>
  <body>
    <Header
      section={section}
      sectionPages={sectionPages}
      currentPageId={currentPageId}
    />
    <div class:list={["site-page", hasContentPageBackground && "site-page-content"]} data-section={section}>
      {hasContentPageBackground && <ContentPageHillsBackground />}
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <FigureModal />
  </body>
</html>

<style>
  .site-page {
    position: relative;
  }

  .site-page-content {
    overflow: clip;
  }

  .site-page-content main,
  .site-page-content :global(.site-footer) {
    position: relative;
    z-index: 1;
  }
</style>
