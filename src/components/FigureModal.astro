<dialog class="figure-modal" data-figure-modal aria-label="Enlarged figure">
  <div class="figure-modal-panel" data-figure-modal-panel>
    <button class="figure-modal-close" type="button" data-figure-modal-close aria-label="Close enlarged figure">
      <span aria-hidden="true">&times;</span>
    </button>
    <img class="figure-modal-image" data-figure-modal-image alt="" />
  </div>
</dialog>

<script>
  (() => {
    const figureModalWindow = window as Window & {
      figureModalController?: AbortController;
    };

    const setupFigureModal = () => {
      const modal = document.querySelector("[data-figure-modal]");

      if (!(modal instanceof HTMLDialogElement) || modal.dataset.initialized === "true") {
        return;
      }

      modal.dataset.initialized = "true";
      figureModalWindow.figureModalController?.abort?.();

      const controller = new AbortController();
      figureModalWindow.figureModalController = controller;
      const { signal } = controller;

      const image = modal.querySelector("[data-figure-modal-image]");
      const closeButton = modal.querySelector("[data-figure-modal-close]");
      let activeTrigger = null;

      const closeModal = () => {
        if (modal.open) {
          modal.close();
        }
      };

      document.addEventListener("click", (event) => {
        const trigger = event.target instanceof Element
          ? event.target.closest("[data-figure-modal-trigger]")
          : null;

        if (!trigger || !(image instanceof HTMLImageElement)) {
          return;
        }

        const src = trigger.getAttribute("data-figure-modal-src");

        if (!src) {
          return;
        }

        event.preventDefault();
        activeTrigger = trigger instanceof HTMLElement ? trigger : null;

        const alt = trigger.getAttribute("data-figure-modal-alt") || "";
        const size = trigger.getAttribute("data-figure-modal-size") || "default";

        image.src = src;
        image.alt = alt;
        modal.dataset.figureModalSize = size;

        modal.showModal();
        closeButton instanceof HTMLElement && closeButton.focus();
      }, { signal });

      closeButton?.addEventListener("click", closeModal, { signal });

      modal.addEventListener("click", (event) => {
        if (event.target === modal) {
          closeModal();
        }
      }, { signal });

      modal.addEventListener("close", () => {
        if (image instanceof HTMLImageElement) {
          image.removeAttribute("src");
          image.alt = "";
        }

        delete modal.dataset.figureModalSize;
        activeTrigger?.focus();
        activeTrigger = null;
      }, { signal });
    };

    setupFigureModal();
    document.addEventListener("astro:page-load", setupFigureModal);
  })();
</script>

<style>
  .figure-modal {
    background: transparent;
    border: 0;
    margin: auto;
    max-height: 100dvh;
    max-width: 100vw;
    overflow: hidden;
    padding: var(--space-md);
  }

  .figure-modal::backdrop {
    background: color-mix(in srgb, var(--color-text) 72%, transparent);
  }

  .figure-modal-panel {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    box-sizing: border-box;
    max-height: calc(100dvh - (2 * var(--space-md)));
    max-width: calc(100vw - (2 * var(--space-md)));
    overflow: hidden;
    padding: var(--space-sm);
    position: relative;
    width: fit-content;
  }

  .figure-modal-close {
    align-items: center;
    background: var(--color-surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--color-text);
    cursor: pointer;
    display: inline-flex;
    font: inherit;
    height: 2.25rem;
    justify-content: center;
    padding: 0;
    position: absolute;
    right: var(--space-md);
    top: var(--space-md);
    width: 2.25rem;
    z-index: 1;
  }

  .figure-modal-close:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .figure-modal-close span {
    font-size: 1.5rem;
    line-height: 1;
    transform: translateY(-0.04em);
  }

  .figure-modal-image {
    display: block;
    height: min(82dvh, calc(100dvh - (2 * var(--space-md)) - (2 * var(--space-sm))));
    justify-self: center;
    max-height: calc(100dvh - (2 * var(--space-md)) - (2 * var(--space-sm)));
    max-width: calc(100vw - (2 * var(--space-md)) - (2 * var(--space-sm)));
    width: auto;
  }

  .figure-modal[data-figure-modal-size="wide"] .figure-modal-image {
    height: calc(100dvh - (2 * var(--space-md)) - (2 * var(--space-sm)));
    max-width: calc(100vw - (2 * var(--space-md)) - (2 * var(--space-sm)));
    width: auto;
  }

  @media (max-width: 700px) {
    .figure-modal {
      padding: var(--space-sm);
    }

    .figure-modal-panel {
      max-height: calc(100dvh - (2 * var(--space-sm)));
      max-width: calc(100vw - (2 * var(--space-sm)));
      padding: var(--space-xs);
    }

    .figure-modal-close {
      right: var(--space-sm);
      top: var(--space-sm);
    }

    .figure-modal-image {
      height: auto;
      max-height: calc(100dvh - (2 * var(--space-sm)) - (2 * var(--space-xs)));
      max-width: calc(100vw - (2 * var(--space-sm)) - (2 * var(--space-xs)));
      width: calc(100vw - (2 * var(--space-sm)) - (2 * var(--space-xs)));
    }

    .figure-modal[data-figure-modal-size="wide"] .figure-modal-image {
      height: auto;
      max-width: calc(100vw - (2 * var(--space-sm)) - (2 * var(--space-xs)));
      width: calc(100vw - (2 * var(--space-sm)) - (2 * var(--space-xs)));
    }
  }
</style>
