---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { githubUrl, navLinks } from "../data/navigation";
import { sectionTitles, type SectionKey, type SectionPage } from "../lib/content";

type Props = {
  section?: SectionKey;
  sectionPages?: SectionPage[];
  currentPageId?: string;
};

const {
  section,
  sectionPages = [],
  currentPageId,
} = Astro.props;
const pathname = Astro.url.pathname;
const sectionTitle = section ? sectionTitles[section] : undefined;

function normalizePath(path: string) {
  return path === "/" ? path : path.replace(/\/$/, "");
}

function isActive(match: string) {
  const currentPath = normalizePath(pathname);
  const matchPath = normalizePath(match);

  return currentPath === matchPath || currentPath.startsWith(`${matchPath}/`);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <Logo />

    <nav class="desktop-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href} aria-current={isActive(link.match) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="icon-link desktop-github" href={githubUrl} aria-label="Oiva on GitHub">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.34-1.75-1.34-1.75-1.09-.75.08-.74.08-.74 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .5Z"></path>
        </svg>
      </a>
      <ThemeToggle class="desktop-theme" />
      <button class="menu-button" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu" data-menu-button>
        <svg class="menu-open-icon" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
        <svg class="menu-close-icon" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden data-mobile-menu>
    <nav aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a href={link.href} aria-current={isActive(link.match) ? "page" : undefined}>
          {link.label}
        </a>
      ))}
      <a href={githubUrl}>GitHub</a>
    </nav>

    {sectionTitle && sectionPages.length > 0 && (
      <nav
        class="mobile-section-nav"
        aria-label={`${sectionTitle} navigation`}
        data-section-accordion
        data-current-page={currentPageId}
      >
        <p>{sectionTitle}</p>
        {sectionPages.map((page) => (
          <div class="mobile-page-nav-item" data-page-id={page.id}>
            <a
              href={page.href}
              aria-current={page.id === currentPageId ? "page" : undefined}
              data-section-page-link
            >
              {page.label}
            </a>
            {page.headings.length > 0 && (
              <div
                class="mobile-page-headings"
                aria-label={`${page.label} headings`}
                aria-hidden={page.id === currentPageId ? "false" : "true"}
                data-open={page.id === currentPageId ? "true" : "false"}
                data-heading-panel
              >
                {page.headings.map((heading) => (
                  <a class="mobile-heading-link" href={`#${heading.slug}`}>{heading.text}</a>
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>
    )}
  </div>
</header>

<script>
  const closeCurrentMobileMenu = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
    const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

    if (!button || !menu) {
      return;
    }

    button.setAttribute("aria-expanded", "false");
    button.setAttribute("aria-label", "Open navigation menu");
    menu.setAttribute("hidden", "");
  };

  const initializeMobileMenu = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
    const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

    if (!button || !menu || button.dataset.menuReady === "true") {
      return;
    }

    button.dataset.menuReady = "true";

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";

      if (isOpen) {
        closeCurrentMobileMenu();
        return;
      }

      button.setAttribute("aria-expanded", "true");
      button.setAttribute("aria-label", "Close navigation menu");
      menu.removeAttribute("hidden");
    });

    menu.addEventListener("click", (event) => {
      const target = event.target;

      if (target instanceof Element && target.closest("a")) {
        closeCurrentMobileMenu();
      }
    });
  };

  initializeMobileMenu();

  if (document.documentElement.dataset.mobileMenuListenerReady !== "true") {
    document.documentElement.dataset.mobileMenuListenerReady = "true";
    document.addEventListener("astro:page-load", initializeMobileMenu);
    document.addEventListener("click", (event) => {
      const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
      const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

      if (!button || !menu || button.getAttribute("aria-expanded") !== "true") {
        return;
      }

      const target = event.target;

      if (!(target instanceof Node) || button.contains(target) || menu.contains(target)) {
        return;
      }

      closeCurrentMobileMenu();
    });
  }
</script>

<style>
  .site-header {
    background: color-mix(in srgb, var(--color-background) 94%, transparent);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-header-inner {
    align-items: center;
    display: flex;
    gap: 1.5rem;
    margin: 0 auto;
    max-width: var(--container-wide);
    min-height: 4.25rem;
    padding: 0 var(--space-page);
  }

  .desktop-nav {
    align-items: center;
    display: flex;
    gap: 0.25rem;
    margin-left: 1rem;
  }

  .desktop-nav a,
  .mobile-menu a {
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
  }

  .desktop-nav a:hover,
  .desktop-nav a[aria-current="page"],
  .mobile-menu a:hover,
  .mobile-menu a[aria-current="page"] {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .header-actions {
    align-items: center;
    display: flex;
    gap: 0.5rem;
    margin-left: auto;
  }

  .icon-link,
  .menu-button {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    display: inline-flex;
    height: 2.25rem;
    justify-content: center;
    width: 2.25rem;
  }

  .icon-link:hover,
  .menu-button:hover {
    background: var(--color-surface-strong);
  }

  .icon-link svg {
    fill: currentColor;
    height: 1.125rem;
    width: 1.125rem;
  }

  .menu-button {
    cursor: pointer;
    display: none;
  }

  .menu-button svg {
    fill: none;
    height: 1.25rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 1.25rem;
  }

  .menu-close-icon,
  .menu-button[aria-expanded="true"] .menu-open-icon {
    display: none;
  }

  .menu-button[aria-expanded="true"] .menu-close-icon {
    display: block;
  }

  .mobile-menu {
    border-top: 1px solid var(--color-border);
    max-height: min(50vh, 26rem);
    overflow-y: auto;
    padding: 1rem var(--space-page) 1.5rem;
    overscroll-behavior: contain;
  }

  .mobile-menu nav {
    display: grid;
    gap: 0.25rem;
  }

  .mobile-section-nav {
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .mobile-section-nav p {
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    text-transform: uppercase;
  }

  .mobile-page-nav-item {
    display: grid;
    gap: 0.125rem;
    min-width: 0;
  }

  .mobile-page-headings {
    display: grid;
    gap: 0.05rem;
    margin: 0 0 0.45rem 0.95rem;
    min-width: 0;
    overflow: hidden;
    transition: none;
  }

  .mobile-page-headings[data-open="false"] {
    height: 0;
    margin-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  .mobile-page-headings[data-open="true"] {
    opacity: 1;
  }

  .mobile-menu .mobile-heading-link {
    border-radius: calc(var(--radius-sm) * 0.75);
    font-size: 0.9rem;
    padding: 0.35rem 0.5rem;
  }

  .mobile-menu .mobile-heading-link:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  @media (max-width: 780px) {
    .desktop-nav,
    .desktop-github,
    .desktop-theme {
      display: none;
    }

    .menu-button {
      display: inline-flex;
    }
  }

</style>
