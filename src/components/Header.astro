---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { githubUrl, navLinks } from "../data/navigation";
import { sectionTitles, type SectionKey, type SectionPage } from "../lib/content";
import { withoutBase } from "../lib/urls";

type Props = {
  section?: SectionKey;
  sectionPages?: SectionPage[];
  currentPageId?: string;
};

const {
  section,
  sectionPages = [],
  currentPageId,
} = Astro.props;
const pathname = withoutBase(Astro.url.pathname);
const sectionTitle = section ? sectionTitles[section] : undefined;

function normalizePath(path: string) {
  return path === "/" ? path : path.replace(/\/$/, "");
}

function isActive(match: string) {
  const currentPath = normalizePath(pathname);
  const matchPath = normalizePath(match);

  return currentPath === matchPath || currentPath.startsWith(`${matchPath}/`);
}

function getHeadingHref(page: SectionPage, slug: string) {
  if (page.id === currentPageId) {
    return `#${slug}`;
  }

  const [pagePath] = page.href.split("#");
  return `${pagePath}#${slug}`;
}

function hasMobilePageToggle(page: SectionPage) {
  return section === "caseStudy" && page.headings.length > 0;
}
---

<header class="site-header">
  <div class="site-header-inner">
    <Logo />

    <nav class="desktop-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        link.children ? (
          <div class="nav-dropdown" data-nav-dropdown>
            <button
              class="nav-dropdown-trigger"
              type="button"
              aria-expanded="false"
              aria-current={isActive(link.match) ? "page" : undefined}
              data-nav-dropdown-trigger
            >
              {link.label}
              <svg aria-hidden="true" viewBox="0 0 16 16">
                <path d="M4 6l4 4 4-4"></path>
              </svg>
            </button>
            <div class="nav-dropdown-menu" hidden data-nav-dropdown-menu>
              {link.children.map((child) => (
                <a href={child.href} aria-current={isActive(child.match) ? "page" : undefined}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} aria-current={isActive(link.match) ? "page" : undefined}>
            {link.label}
          </a>
        )
      ))}
    </nav>

    <div class="header-actions">
      <a class="icon-link desktop-github" href={githubUrl} aria-label="Oiva on GitHub" target="_blank" rel="noopener noreferrer">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.34-1.75-1.34-1.75-1.09-.75.08-.74.08-.74 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .5Z"></path>
        </svg>
      </a>
      <ThemeToggle class="desktop-theme" />
      <button class="menu-button" type="button" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu" data-menu-button>
        <svg class="menu-open-icon" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
        <svg class="menu-close-icon" aria-hidden="true" viewBox="0 0 24 24">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden data-mobile-menu>
    <nav aria-label="Mobile navigation">
      {navLinks.map((link) => (
        link.children ? (
          <div class="mobile-nav-group">
            <a href={link.href} aria-current={isActive(link.match) ? "page" : undefined}>
              {link.label}
            </a>
            <div class="mobile-nav-children">
              {link.children.map((child) => (
                <a href={child.href} aria-current={isActive(child.match) ? "page" : undefined}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} aria-current={isActive(link.match) ? "page" : undefined}>
            {link.label}
          </a>
        )
      ))}
      <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>

    {sectionTitle && sectionPages.length > 0 && (
      <nav
        class="mobile-section-nav"
        aria-label={`${sectionTitle} navigation`}
        data-section-accordion
        data-current-page={currentPageId}
      >
        <p>{sectionTitle}</p>
        {sectionPages.map((page) => (
          <div class="mobile-page-nav-item" data-page-id={page.id}>
            {hasMobilePageToggle(page) ? (
              <div class="mobile-page-link-row">
                <a
                  href={page.href}
                  aria-current={page.id === currentPageId ? "page" : undefined}
                  data-section-page-link
                >
                  {page.label}
                </a>
                <button
                  class="mobile-page-toggle"
                  type="button"
                  aria-expanded={page.id === currentPageId ? "true" : "false"}
                  aria-label={`Toggle ${page.label} subsections`}
                  data-section-toggle
                >
                  <svg aria-hidden="true" viewBox="0 0 16 16">
                    <path d="M6 4l4 4-4 4"></path>
                  </svg>
                </button>
              </div>
            ) : (
              <a
                href={page.href}
                aria-current={page.id === currentPageId ? "page" : undefined}
                data-section-page-link
              >
                {page.label}
              </a>
            )}
            {page.headings.length > 0 && (
              <div
                class="mobile-page-headings"
                aria-label={`${page.label} headings`}
                aria-hidden={page.id === currentPageId ? "false" : "true"}
                data-open={page.id === currentPageId ? "true" : "false"}
                data-heading-panel
              >
                {page.headings.map((heading) => (
                  <div class="mobile-heading-nav-item" data-heading-id={heading.slug}>
                    <div class:list={["mobile-heading-link-row", heading.children?.length && "has-heading-children"]}>
                      <a
                        class:list={["mobile-heading-link", `mobile-heading-link-depth-${heading.depth}`]}
                        href={getHeadingHref(page, heading.slug)}
                        data-heading-link
                      >
                        {heading.text}
                      </a>
                      {heading.children && heading.children.length > 0 && (
                        <button
                          class="mobile-heading-toggle"
                          type="button"
                          aria-expanded="false"
                          aria-label={`Toggle ${heading.text} subsections`}
                          data-heading-toggle
                        >
                          <svg aria-hidden="true" viewBox="0 0 16 16">
                            <path d="M6 4l4 4-4 4"></path>
                          </svg>
                        </button>
                      )}
                    </div>
                    {heading.children && heading.children.length > 0 && (
                      <div
                        class="mobile-heading-children"
                        aria-label={`${heading.text} subsections`}
                        aria-hidden="true"
                        data-open="false"
                        data-nested-heading-panel
                      >
                        {heading.children.map((child) => (
                          <a
                            class="mobile-heading-link mobile-heading-link-depth-3"
                            href={getHeadingHref(page, child.slug)}
                            data-heading-link
                          >
                            {child.text}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </nav>
    )}
  </div>
</header>

<script>
  const closeCurrentMobileMenu = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
    const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

    if (!button || !menu) {
      return;
    }

    button.setAttribute("aria-expanded", "false");
    button.setAttribute("aria-label", "Open navigation menu");
    menu.setAttribute("hidden", "");
  };

  const closeAllNavDropdowns = () => {
    document.querySelectorAll<HTMLElement>("[data-nav-dropdown]").forEach((dropdown) => {
      const trigger = dropdown.querySelector<HTMLButtonElement>("[data-nav-dropdown-trigger]");
      const menu = dropdown.querySelector<HTMLElement>("[data-nav-dropdown-menu]");

      trigger?.setAttribute("aria-expanded", "false");
      menu?.setAttribute("hidden", "");
    });
  };

  const initializeNavDropdowns = () => {
    document.querySelectorAll<HTMLElement>("[data-nav-dropdown]").forEach((dropdown) => {
      const trigger = dropdown.querySelector<HTMLButtonElement>("[data-nav-dropdown-trigger]");
      const menu = dropdown.querySelector<HTMLElement>("[data-nav-dropdown-menu]");

      if (!trigger || !menu || dropdown.dataset.dropdownReady === "true") {
        return;
      }

      dropdown.dataset.dropdownReady = "true";

      trigger.addEventListener("click", () => {
        const isOpen = trigger.getAttribute("aria-expanded") === "true";

        closeAllNavDropdowns();

        if (isOpen) {
          return;
        }

        trigger.setAttribute("aria-expanded", "true");
        menu.removeAttribute("hidden");
      });

      menu.addEventListener("click", (event) => {
        const target = event.target;

        if (target instanceof Element && target.closest("a")) {
          closeAllNavDropdowns();
        }
      });
    });
  };

  const initializeMobileMenu = () => {
    const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
    const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

    if (!button || !menu || button.dataset.menuReady === "true") {
      return;
    }

    button.dataset.menuReady = "true";

    button.addEventListener("click", () => {
      const isOpen = button.getAttribute("aria-expanded") === "true";

      if (isOpen) {
        closeCurrentMobileMenu();
        return;
      }

      button.setAttribute("aria-expanded", "true");
      button.setAttribute("aria-label", "Close navigation menu");
      menu.removeAttribute("hidden");
    });

    menu.addEventListener("click", (event) => {
      const target = event.target;

      if (target instanceof Element && target.closest("a")) {
        closeCurrentMobileMenu();
      }
    });
  };

  initializeMobileMenu();
  initializeNavDropdowns();

  if (document.documentElement.dataset.mobileMenuListenerReady !== "true") {
    document.documentElement.dataset.mobileMenuListenerReady = "true";
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeAllNavDropdowns();
      }
    });
    document.addEventListener("click", (event) => {
      const button = document.querySelector<HTMLButtonElement>("[data-menu-button]");
      const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
      const target = event.target;

      const dropdowns = Array.from(document.querySelectorAll<HTMLElement>("[data-nav-dropdown]"));
      const isInsideDropdown = target instanceof Node
        && dropdowns.some((dropdown) => dropdown.contains(target));

      if (!isInsideDropdown) {
        closeAllNavDropdowns();
      }

      if (!button || !menu || button.getAttribute("aria-expanded") !== "true") {
        return;
      }

      if (!(target instanceof Node) || button.contains(target) || menu.contains(target)) {
        return;
      }

      closeCurrentMobileMenu();
    });
  }
</script>

<style>
  .site-header {
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .site-header-inner {
    align-items: center;
    display: flex;
    gap: var(--space-lg);
    margin: 0 auto;
    max-width: var(--container-page);
    min-height: var(--header-height);
    padding: 0 var(--space-page);
  }

  .desktop-nav {
    align-items: center;
    display: flex;
    gap: var(--space-2xs);
    margin-left: var(--space-md);
  }

  .desktop-nav a,
  .nav-dropdown-trigger,
  .mobile-menu a {
    align-items: center;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    display: inline-flex;
    font-size: var(--text-sm);
    font-weight: 600;
    gap: 0.35rem;
    line-height: var(--leading-ui);
    padding: var(--space-xs) var(--space-sm);
    text-decoration: none;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: inherit;
  }

  .nav-dropdown-trigger svg {
    fill: none;
    height: 0.875rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transition: transform 140ms ease;
    width: 0.875rem;
  }

  .nav-dropdown-trigger[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    display: grid;
    gap: var(--space-2xs);
    left: 0;
    min-width: 12rem;
    padding: var(--space-xs);
    position: absolute;
    top: calc(100% + var(--space-xs));
    z-index: 30;
  }

  .nav-dropdown-menu[hidden] {
    display: none;
  }

  .nav-dropdown-menu a {
    display: flex;
    white-space: nowrap;
  }

  .desktop-nav a:hover,
  .desktop-nav a[aria-current="page"],
  .nav-dropdown-trigger:hover,
  .nav-dropdown-trigger[aria-current="page"],
  .mobile-menu a:hover,
  .mobile-menu a[aria-current="page"] {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  .header-actions {
    align-items: center;
    display: flex;
    gap: var(--space-xs);
    margin-left: auto;
  }

  .icon-link,
  .menu-button {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    display: inline-flex;
    height: 2.35rem;
    justify-content: center;
    width: 2.35rem;
  }

  .icon-link:hover,
  .menu-button:hover {
    background: var(--color-surface-raised);
    border-color: var(--border-strong);
  }

  .icon-link svg {
    fill: currentColor;
    height: 1.125rem;
    width: 1.125rem;
  }

  .menu-button {
    cursor: pointer;
    display: none;
  }

  .menu-button svg {
    fill: none;
    height: 1.25rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    width: 1.25rem;
  }

  .menu-close-icon,
  .menu-button[aria-expanded="true"] .menu-open-icon {
    display: none;
  }

  .menu-button[aria-expanded="true"] .menu-close-icon {
    display: block;
  }

  .mobile-menu {
    background: color-mix(in srgb, var(--color-bg) 94%, var(--color-surface));
    border-top: 1px solid var(--border-subtle);
    max-height: min(50vh, 26rem);
    overflow-y: auto;
    padding: var(--space-md) var(--space-page) var(--space-lg);
    overscroll-behavior: contain;
  }

  .mobile-menu nav {
    display: grid;
    gap: var(--space-2xs);
  }

  .mobile-nav-group {
    display: grid;
    gap: var(--space-2xs);
  }

  .mobile-nav-children {
    display: grid;
    gap: var(--space-2xs);
    margin-left: var(--space-md);
  }

  .mobile-nav-children a {
    font-size: var(--text-sm);
    font-weight: 600;
  }

  .mobile-section-nav {
    border-top: 1px solid var(--border-subtle);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
  }

  .mobile-section-nav p {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 700;
    margin: 0 0 0.375rem;
    text-transform: uppercase;
  }

  .mobile-page-nav-item {
    display: grid;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .mobile-page-link-row {
    align-items: center;
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: minmax(0, 1fr) 1.75rem;
    min-width: 0;
  }

  .mobile-page-headings {
    display: grid;
    gap: var(--space-2xs);
    margin: 0 0 0.45rem 0.95rem;
    min-width: 0;
    overflow: hidden;
    transition: none;
  }

  .mobile-page-headings[data-open="false"] {
    height: 0;
    margin-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  .mobile-page-headings[data-open="true"] {
    opacity: 1;
  }

  .mobile-menu .mobile-heading-link {
    border-radius: var(--radius-xs);
    font-size: var(--text-sm);
    padding: 0.35rem 0.5rem;
  }

  .mobile-menu .mobile-heading-link-depth-2 {
    color: color-mix(in srgb, var(--color-text-muted) 88%, var(--color-text-subtle));
    font-size: 0.84rem;
    font-weight: 680;
    padding-left: 0.45rem;
  }

  .mobile-heading-nav-item {
    display: grid;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .mobile-heading-link-row {
    align-items: center;
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: minmax(0, 1fr);
    min-width: 0;
  }

  .mobile-heading-link-row.has-heading-children {
    grid-template-columns: minmax(0, 1fr) 1.75rem;
  }

  .mobile-page-toggle,
  .mobile-heading-toggle {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    border-radius: var(--radius-xs);
    color: var(--color-text-subtle);
    cursor: pointer;
    display: inline-flex;
    height: 1.75rem;
    justify-content: center;
    padding: 0;
    width: 1.75rem;
  }

  .mobile-page-toggle:hover,
  .mobile-heading-toggle:hover {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  .mobile-page-toggle svg,
  .mobile-heading-toggle svg {
    fill: none;
    height: 0.875rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transition: transform 180ms ease;
    width: 0.875rem;
  }

  .mobile-page-toggle[aria-expanded="true"] svg,
  .mobile-heading-toggle[aria-expanded="true"] svg {
    transform: rotate(90deg);
  }

  .mobile-heading-children {
    border-left: 1px solid color-mix(in srgb, var(--color-primary) 24%, transparent);
    display: grid;
    gap: var(--space-2xs);
    margin-left: 0.75rem;
    min-width: 0;
    overflow: hidden;
    padding-left: 0.75rem;
    transition: none;
  }

  .mobile-heading-children[data-open="false"] {
    height: 0;
    opacity: 0;
    pointer-events: none;
  }

  .mobile-heading-children[data-open="true"] {
    opacity: 1;
  }

  .mobile-menu .mobile-heading-link-depth-3 {
    color: color-mix(in srgb, var(--color-text-subtle) 86%, transparent);
    font-size: var(--text-xs);
    font-weight: 600;
    padding-left: 0.45rem;
  }

  .mobile-menu .mobile-heading-link:hover {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  /* two-column breakpoint — must find-and-replace to keep in sync! */
  @media (max-width: 1200px) {
    .desktop-nav,
    .desktop-github,
    .desktop-theme {
      display: none;
    }

    .menu-button {
      display: inline-flex;
    }
  }

</style>
