---
import { Image } from "astro:assets";

type Props = {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  sourceLabel?: string;
  sourceUrl?: string;
};

const { src, alt, caption, sourceLabel = "Open full size", sourceUrl } = Astro.props;
const fullSizeHref = sourceUrl ?? (typeof src === "string" ? src : src.src);
const isSvg = typeof src !== "string" && src.format === "svg";
---

<figure>
  <a href={fullSizeHref}>
    {isSvg || typeof src === "string" ? (
      <img src={typeof src === "string" ? src : src.src} alt={alt} loading="lazy" />
    ) : (
      <Image src={src} alt={alt} widths={[640, 960, 1280, 1600]} sizes="(max-width: 900px) 100vw, 760px" />
    )}
  </a>
  {(caption || sourceLabel) && (
    <figcaption>
      {caption && <span>{caption}</span>}
      <a href={fullSizeHref}>{sourceLabel}</a>
    </figcaption>
  )}
</figure>

<style>
  figure {
    margin: 2rem 0;
  }

  figure > a {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: block;
    overflow: hidden;
  }

  img {
    display: block;
    height: auto;
    width: 100%;
  }

  figcaption {
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.9rem;
    gap: 0.75rem;
    justify-content: space-between;
    line-height: 1.45;
    margin-top: 0.6rem;
  }
</style>
