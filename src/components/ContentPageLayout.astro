---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionSidebar from "./SectionSidebar.astro";
import {
  sectionTitles,
  type SectionKey,
  type SectionPage,
} from "../lib/content";

type Props = {
  section: SectionKey;
  title: string;
  description: string;
  currentPageId: string;
  pages: SectionPage[];
};

const { section, title, description, currentPageId, pages } = Astro.props;
const sectionTitle = sectionTitles[section];
const usesFramedContentLayout = section === "caseStudy" || section === "getStarted";
---

<BaseLayout
  title={title}
  description={description}
  section={section}
  sectionPages={pages}
  currentPageId={currentPageId}
>
  <div class:list={["content-shell", usesFramedContentLayout && "content-shell-framed"]} data-section={section}>
    <SectionSidebar title={sectionTitle} pages={pages} currentPageId={currentPageId} />

    <article class="content-article">
      <p class="eyebrow">{sectionTitle}</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .content-shell {
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: minmax(13rem, var(--sidebar-width)) minmax(0, var(--container-content));
    margin: 0 auto;
    max-width: var(--container-page);
    padding: var(--space-md) var(--space-page) 0;
    position: relative;
  }

  .content-article {
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .content-shell-framed {
    gap: var(--space-xl);
    grid-template-columns: minmax(13rem, var(--sidebar-width)) minmax(0, 1fr);
    max-width: 1520px;
    min-height: calc(100vh - var(--header-height));
  }

  .content-shell-framed .content-article {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    padding: var(--space-2xl);
  }

  .content-shell-framed .prose {
    max-width: none;
    width: 100%;
  }

  h1 {
    font-size: var(--text-3xl);
    letter-spacing: 0;
    line-height: var(--leading-tight);
    margin: 0;
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--text-md);
    line-height: 1.62;
    margin: var(--space-md) 0 var(--space-xl);
  }

  @media (max-width: 1100px) {
    .content-shell {
      display: block;
      padding-top: var(--space-xl);
    }

    .content-shell-framed .content-article {
      padding: var(--space-lg);
    }
  }
</style>
