---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionSidebar from "./SectionSidebar.astro";
import {
  getAdjacentPages,
  sectionTitles,
  type SectionKey,
  type SectionPage,
} from "../lib/content";

type Props = {
  section: SectionKey;
  title: string;
  description: string;
  currentPageId: string;
  pages: SectionPage[];
};

const { section, title, description, currentPageId, pages } = Astro.props;
const sectionTitle = sectionTitles[section];
const { previous, next } = getAdjacentPages(pages, currentPageId);
const hasPager = Boolean(previous || next);
---

<BaseLayout
  title={title}
  description={description}
  section={section}
  sectionPages={pages}
  currentPageId={currentPageId}
>
  <div class="content-shell">
    <SectionSidebar title={sectionTitle} pages={pages} currentPageId={currentPageId} />

    <article class="content-article">
      <p class="eyebrow">{sectionTitle}</p>
      <h1>{title}</h1>
      <p class="description">{description}</p>
      <div class="prose">
        <slot />
      </div>

      {hasPager && (
        <nav class="pager" aria-label="Previous and next pages">
          {previous && (
            <a class="pager-link" href={previous.href}>
              <span>Previous</span>
              <strong>{previous.label}</strong>
            </a>
          )}

          {next && (
            <a class="pager-link pager-link-next" href={next.href}>
              <span>Next</span>
              <strong>{next.label}</strong>
            </a>
          )}
        </nav>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .content-shell {
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: minmax(13rem, var(--sidebar-width)) minmax(0, var(--container-content));
    margin: 0 auto;
    max-width: var(--container-page);
    padding: var(--space-2xl) var(--space-page) 0;
  }

  .content-article {
    min-width: 0;
  }

  h1 {
    font-size: var(--text-3xl);
    letter-spacing: 0;
    line-height: var(--leading-tight);
    margin: 0;
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--text-md);
    line-height: 1.62;
    margin: var(--space-md) 0 var(--space-xl);
  }

  .pager {
    border-top: 1px solid var(--border-subtle);
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 1fr 1fr;
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
  }

  .pager-link {
    background: var(--color-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    color: var(--color-text);
    display: grid;
    gap: var(--space-2xs);
    line-height: var(--leading-ui);
    padding: var(--space-md);
    text-decoration: none;
  }

  .pager-link:hover {
    background: var(--color-surface-raised);
    border-color: var(--border-strong);
    color: var(--color-text);
  }

  .pager-link span {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
  }

  .pager-link-next {
    grid-column: 2;
    text-align: right;
  }

  @media (max-width: 900px) {
    .content-shell {
      display: block;
      padding-top: var(--space-xl);
    }

    .pager {
      grid-template-columns: 1fr;
    }

    .pager-link-next {
      grid-column: auto;
      text-align: left;
    }
  }
</style>
