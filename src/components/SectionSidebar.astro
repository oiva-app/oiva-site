---
import type { SectionPage } from "../lib/content";

type Props = {
  title: string;
  pages: SectionPage[];
  currentPageId: string;
};

const { title, pages, currentPageId } = Astro.props;

function getHeadingHref(page: SectionPage, slug: string) {
  if (page.id === currentPageId) {
    return `#${slug}`;
  }

  const [pagePath] = page.href.split("#");
  return `${pagePath}#${slug}`;
}
---

<aside
  class="section-sidebar"
  data-section-accordion
  data-current-page={currentPageId}
>
  <nav aria-label={`${title} pages`}>
    <p class="sidebar-title">{title}</p>
    {pages.map((page) => (
      <div class="page-nav-item" data-page-id={page.id}>
        <div class="page-link-row">
          <a
            class="page-link"
            href={page.href}
            aria-current={page.id === currentPageId ? "page" : undefined}
            data-section-page-link
          >
            {page.label}
          </a>
          {page.headings.length > 0 && (
            <button
              class="page-toggle"
              type="button"
              aria-expanded={page.id === currentPageId ? "true" : "false"}
              aria-label={`Toggle ${page.label} subsections`}
              data-section-toggle
            >
              <svg class="toggle-icon" aria-hidden="true" viewBox="0 0 16 16">
                <path d="M6 4l4 4-4 4"></path>
              </svg>
            </button>
          )}
        </div>
        {page.headings.length > 0 && (
          <div
            class="page-headings"
            aria-label={`${page.label} headings`}
            aria-hidden={page.id === currentPageId ? "false" : "true"}
            data-open={page.id === currentPageId ? "true" : "false"}
            data-heading-panel
          >
            {page.headings.map((heading) => (
              <div class="heading-nav-item" data-heading-id={heading.slug}>
                <div class:list={["heading-link-row", heading.children?.length && "has-heading-children"]}>
                  <a
                    class:list={["heading-link", `heading-link-depth-${heading.depth}`]}
                    href={getHeadingHref(page, heading.slug)}
                    data-heading-link
                  >
                    {heading.text}
                  </a>
                  {heading.children && heading.children.length > 0 && (
                    <button
                      class="heading-toggle"
                      type="button"
                      aria-expanded="false"
                      aria-label={`Toggle ${heading.text} subsections`}
                      data-heading-toggle
                    >
                      <svg class="toggle-icon" aria-hidden="true" viewBox="0 0 16 16">
                        <path d="M6 4l4 4-4 4"></path>
                      </svg>
                    </button>
                  )}
                </div>
                {heading.children && heading.children.length > 0 && (
                  <div
                    class="heading-children"
                    aria-label={`${heading.text} subsections`}
                    aria-hidden="true"
                    data-open="false"
                    data-nested-heading-panel
                  >
                    {heading.children.map((child) => (
                      <a
                        class="heading-link heading-link-depth-3"
                        href={getHeadingHref(page, child.slug)}
                        data-heading-link
                      >
                        {child.text}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>
</aside>

<script>
  type PanelElement = HTMLElement & { dataset: DOMStringMap };

  const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const transitionCleanup = new WeakMap<PanelElement, () => void>();
  let panelTransitionId = 0;

  const setPanelOpen = (
    panel: PanelElement,
    isOpen: boolean,
    animate: boolean,
  ) => {
    transitionCleanup.get(panel)?.();

    const transitionId = `${++panelTransitionId}`;
    panel.dataset.transitionId = transitionId;
    panel.dataset.open = isOpen ? "true" : "false";
    panel.setAttribute("aria-hidden", isOpen ? "false" : "true");

    const toggle = panel.previousElementSibling?.querySelector<HTMLButtonElement>(
      "[data-section-toggle], [data-heading-toggle]",
    );
    toggle?.setAttribute("aria-expanded", isOpen ? "true" : "false");

    if (reducedMotionQuery.matches || !animate) {
      transitionCleanup.delete(panel);
      panel.style.height = isOpen ? "auto" : "0px";
      return;
    }

    const startHeight = panel.offsetHeight;
    const endHeight = isOpen ? panel.scrollHeight : 0;

    panel.style.height = `${startHeight}px`;

    requestAnimationFrame(() => {
      if (panel.dataset.transitionId !== transitionId) {
        return;
      }

      panel.style.height = `${endHeight}px`;
    });

    const finishTransition = (event: TransitionEvent) => {
      if (event.propertyName !== "height") {
        return;
      }

      cleanupTransition();

      if (panel.dataset.transitionId !== transitionId) {
        return;
      }

      if (panel.dataset.open === "true" && isOpen) {
        panel.style.height = "auto";
        return;
      }

      if (panel.dataset.open === "false" && !isOpen) {
        panel.style.height = "0px";
      }
    };

    const cleanupTransition = () => {
      panel.removeEventListener("transitionend", finishTransition);
      transitionCleanup.delete(panel);
    };

    transitionCleanup.set(panel, cleanupTransition);
    panel.addEventListener("transitionend", finishTransition);
  };

  const getPanelForItem = (item: HTMLElement) =>
    item.querySelector<PanelElement>("[data-heading-panel]");

  const getNestedPanelForItem = (item: HTMLElement) =>
    item.querySelector<PanelElement>("[data-nested-heading-panel]");

  const normalizePathname = (pathname: string) => pathname.replace(/\/$/, "");

  const isSamePathname = (url: URL) =>
    normalizePathname(url.pathname) === normalizePathname(window.location.pathname);

  const initializeSectionAccordions = () => {
    document.querySelectorAll<HTMLElement>("[data-section-accordion]").forEach((accordion) => {
      const panels = Array.from(accordion.querySelectorAll<PanelElement>("[data-heading-panel]"));
      const items = Array.from(accordion.querySelectorAll<HTMLElement>("[data-page-id]"));
      const hash = window.location.hash.replace(/^#/, "");
      const matchingHashItem = items.find((item) => {
        if (item.dataset.pageId === hash) {
          return true;
        }

        return Boolean(hash && item.querySelector(`a[href$="#${CSS.escape(hash)}"]`));
      });
      const fallbackItem = items.find((item) => item.dataset.pageId === accordion.dataset.currentPage)
        ?? items[0];
      const initiallyOpenItem = matchingHashItem ?? fallbackItem;

      panels.forEach((panel) => {
        const item = panel.closest<HTMLElement>("[data-page-id]");
        const shouldBeOpen = item === initiallyOpenItem || panel.dataset.open === "true";
        const isCurrentlyOpen = panel.dataset.open === "true";

        if (shouldBeOpen !== isCurrentlyOpen) {
          setPanelOpen(panel, shouldBeOpen, false);
        }
      });

      if (accordion.dataset.accordionReady === "true") {
        return;
      }

      accordion.dataset.accordionReady = "true";

      accordion.addEventListener("click", (event) => {
        const target = event.target;
        const toggle = target instanceof Element
          ? target.closest<HTMLButtonElement>("[data-section-toggle]")
          : null;

        if (toggle) {
          const item = toggle.closest<HTMLElement>("[data-page-id]");
          const panel = item ? getPanelForItem(item) : null;

          if (!panel) {
            return;
          }

          setPanelOpen(panel, panel.dataset.open !== "true", true);
          return;
        }

        const headingToggle = target instanceof Element
          ? target.closest<HTMLButtonElement>("[data-heading-toggle]")
          : null;

        if (headingToggle) {
          const item = headingToggle.closest<HTMLElement>("[data-heading-id]");
          const panel = item ? getNestedPanelForItem(item) : null;

          if (!panel) {
            return;
          }

          setPanelOpen(panel, panel.dataset.open !== "true", true);
          return;
        }

        const headingLink = target instanceof Element
          ? target.closest<HTMLAnchorElement>("[data-heading-link]")
          : null;

        if (headingLink) {
          const linkUrl = new URL(headingLink.href);
          const isSamePageLink = isSamePathname(linkUrl);
          const item = headingLink.closest<HTMLElement>("[data-heading-id]");
          const panel = item ? getNestedPanelForItem(item) : null;

          if (isSamePageLink && panel) {
            setPanelOpen(panel, true, true);
          }

          return;
        }

        const link = target instanceof Element
          ? target.closest<HTMLAnchorElement>("[data-section-page-link]")
          : null;

        if (!link) {
          return;
        }

        const linkUrl = new URL(link.href);
        const isSamePageLink = isSamePathname(linkUrl);

        if (!isSamePageLink) {
          return;
        }

        const item = link.closest<HTMLElement>("[data-page-id]");
        const panel = item ? getPanelForItem(item) : null;
        if (panel) {
          setPanelOpen(panel, true, true);
        }
      });
    });
  };

  initializeSectionAccordions();

  if (document.documentElement.dataset.sectionAccordionListenerReady !== "true") {
    document.documentElement.dataset.sectionAccordionListenerReady = "true";
    window.addEventListener("hashchange", initializeSectionAccordions);
  }
</script>

<style>
  .section-sidebar {
    --section-sidebar-gap: var(--space-md);
    --section-sidebar-max-height: calc(100dvh - var(--header-height) - (var(--section-sidebar-gap) * 2));
    --section-sidebar-scrollbar-bg: color-mix(in srgb, var(--color-surface) 86%, transparent);

    align-self: start;
    background: var(--section-sidebar-scrollbar-bg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    box-sizing: border-box;
    clip-path: inset(0 round var(--radius-lg));
    display: block;
    max-height: var(--section-sidebar-max-height);
    overflow: hidden;
    padding: var(--space-sm) 0;
    position: sticky;
    top: calc(var(--header-height) + var(--section-sidebar-gap));
  }

  nav {
    align-content: start;
    display: grid;
    gap: var(--space-2xs);
    grid-auto-rows: max-content;
    max-height: calc(var(--section-sidebar-max-height) - (var(--space-sm) * 2));
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    padding: calc(var(--space-md) - var(--space-sm)) var(--space-md);
    scrollbar-gutter: stable;
    scrollbar-color:
      color-mix(in srgb, var(--color-primary) 24%, transparent)
      transparent;
    scrollbar-width: thin;
  }

  nav::-webkit-scrollbar {
    width: 6px;
  }

  nav::-webkit-scrollbar-button {
    -webkit-appearance: none;
    appearance: none;
    background: var(--section-sidebar-scrollbar-bg);
    background-color: var(--section-sidebar-scrollbar-bg);
    background-image: none;
    block-size: 0;
    border: 0;
    color: transparent;
    display: none;
    height: 0;
    inline-size: 0;
    min-height: 0;
    min-width: 0;
    padding: 0;
    width: 0;
  }

  nav::-webkit-scrollbar-button:hover,
  nav::-webkit-scrollbar-button:active {
    background: var(--section-sidebar-scrollbar-bg);
    background-color: var(--section-sidebar-scrollbar-bg);
    background-image: none;
    color: transparent;
  }

  nav::-webkit-scrollbar-button:single-button {
    display: none;
    height: 0;
    width: 0;
  }

  nav::-webkit-scrollbar-button:vertical:start,
  nav::-webkit-scrollbar-button:vertical:end {
    display: none;
    height: 0;
    width: 0;
  }

  nav::-webkit-scrollbar-button:vertical:increment,
  nav::-webkit-scrollbar-button:vertical:decrement {
    display: none;
    height: 0;
    width: 0;
  }

  nav::-webkit-scrollbar-button:increment,
  nav::-webkit-scrollbar-button:decrement {
    display: none;
    height: 0;
    width: 0;
  }

  nav::-webkit-scrollbar-track {
    background: transparent;
  }

  nav::-webkit-scrollbar-corner {
    background: transparent;
  }

  nav::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--color-primary) 22%, transparent);
    border-radius: 3px;
  }

  nav::-webkit-scrollbar-thumb:hover {
    background: color-mix(in srgb, var(--color-primary) 36%, transparent);
  }

  .sidebar-title {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 800;
    line-height: var(--leading-ui);
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
  }

  .page-nav-item {
    display: grid;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .page-link-row {
    align-items: center;
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: minmax(0, 1fr) 1.5rem;
    min-width: 0;
  }

  .page-toggle {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    border-radius: var(--radius-xs);
    color: var(--color-text-subtle);
    cursor: pointer;
    display: inline-flex;
    height: 1.5rem;
    justify-content: center;
    padding: 0;
    width: 1.5rem;
  }

  .page-toggle:hover {
    background: var(--color-surface-raised);
    color: var(--color-text);
  }

  .toggle-icon {
    height: 0.8rem;
    transition: transform 180ms ease;
    width: 0.8rem;
  }

  .toggle-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .page-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(90deg);
  }

  a {
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    display: block;
    font-size: var(--text-sm);
    font-weight: 650;
    line-height: var(--leading-ui);
    padding: 0.45rem 0.6rem;
    text-decoration: none;
  }

  .page-link {
    color: color-mix(in srgb, var(--color-text) 72%, var(--color-text-muted));
    font-size: 0.94rem;
    font-weight: 750;
    min-width: 0;
  }

  a:hover,
  a[aria-current="page"],
  .page-link:hover,
  .page-link:focus-visible {
    background: var(--color-primary-soft);
    color: var(--color-text);
  }

  .page-headings {
    display: grid;
    gap: var(--space-2xs);
    margin: 0 1.45rem 0.5rem 1.05rem;
    min-width: 0;
    overflow: hidden;
    transition: height 360ms ease, opacity 280ms ease;
  }

  .page-headings[data-open="false"] {
    height: 0;
    margin-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  .page-headings[data-open="true"] {
    opacity: 1;
  }

  .heading-link {
    border-radius: var(--radius-xs);
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.28rem 0.45rem;
  }

  .heading-link-depth-2 {
    color: color-mix(in srgb, var(--color-text-muted) 88%, var(--color-text-subtle));
    font-size: 0.79rem;
    font-weight: 680;
    padding-left: 0.35rem;
  }

  .heading-nav-item {
    display: grid;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .heading-link-row {
    align-items: center;
    display: grid;
    gap: var(--space-2xs);
    grid-template-columns: minmax(0, 1fr);
    min-width: 0;
  }

  .heading-link-row.has-heading-children {
    grid-template-columns: minmax(0, 1fr) 1.35rem;
  }

  .heading-toggle {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    border-radius: var(--radius-xs);
    color: var(--color-text-subtle);
    cursor: pointer;
    display: inline-flex;
    height: 1.25rem;
    justify-content: center;
    padding: 0;
    width: 1.25rem;
  }

  .heading-toggle:hover {
    background: var(--color-surface-raised);
    color: var(--color-text);
  }

  .heading-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(90deg);
  }

  .heading-children {
    border-left: 1px solid color-mix(in srgb, var(--color-primary) 24%, transparent);
    display: grid;
    gap: var(--space-2xs);
    margin-left: 0.55rem;
    min-width: 0;
    overflow: hidden;
    padding-left: 0.55rem;
    transition: height 260ms ease, opacity 200ms ease;
  }

  .heading-children[data-open="false"] {
    height: 0;
    opacity: 0;
    pointer-events: none;
  }

  .heading-children[data-open="true"] {
    opacity: 1;
  }

  .heading-link-depth-3 {
    color: color-mix(in srgb, var(--color-text-subtle) 86%, transparent);
    font-size: 0.74rem;
    font-weight: 600;
    padding-left: 0.35rem;
  }

  .heading-link:hover,
  .heading-link:focus-visible {
    background: var(--color-surface-raised);
    color: var(--color-text);
  }

  .heading-link-depth-2:hover,
  .heading-link-depth-2:focus-visible {
    background: color-mix(in srgb, var(--color-surface-raised) 72%, transparent);
  }

  @media (max-width: 900px) {
    .section-sidebar {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-headings {
      transition: none;
    }
  }
</style>
