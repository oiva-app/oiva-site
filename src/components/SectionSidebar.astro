---
import type { SectionPage } from "../lib/content";

type Props = {
  title: string;
  pages: SectionPage[];
  currentPageId: string;
};

const { title, pages, currentPageId } = Astro.props;
---

<aside class="section-sidebar" data-section-accordion data-current-page={currentPageId}>
  <nav aria-label={`${title} pages`}>
    <p class="sidebar-title">{title}</p>
    {pages.map((page) => (
      <div class="page-nav-item" data-page-id={page.id}>
        <a
          class="page-link"
          href={page.href}
          aria-current={page.id === currentPageId ? "page" : undefined}
          data-section-page-link
        >
          {page.label}
        </a>
        {page.headings.length > 0 && (
          <div
            class="page-headings"
            aria-label={`${page.label} headings`}
            aria-hidden={page.id === currentPageId ? "false" : "true"}
            data-open={page.id === currentPageId ? "true" : "false"}
            data-heading-panel
          >
            {page.headings.map((heading) => (
              <a class="heading-link" href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>
</aside>

<script>
  type PanelElement = HTMLElement & { dataset: DOMStringMap };

  const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

  const setPanelOpen = (
    panel: PanelElement,
    isOpen: boolean,
    animate: boolean,
    openFromCollapsed = false,
  ) => {
    panel.dataset.open = isOpen ? "true" : "false";
    panel.setAttribute("aria-hidden", isOpen ? "false" : "true");

    if (reducedMotionQuery.matches || !animate) {
      panel.style.height = isOpen ? "auto" : "0px";
      return;
    }

    const startHeight = openFromCollapsed ? 0 : panel.offsetHeight;
    const endHeight = isOpen ? panel.scrollHeight : 0;

    panel.style.height = `${startHeight}px`;

    requestAnimationFrame(() => {
      panel.style.height = `${endHeight}px`;
    });

    const finishTransition = (event: TransitionEvent) => {
      if (event.propertyName !== "height") {
        return;
      }

      panel.removeEventListener("transitionend", finishTransition);

      if (isOpen) {
        panel.style.height = "auto";
      }
    };

    panel.addEventListener("transitionend", finishTransition);
  };

  const initializeSectionAccordions = () => {
    const shouldAnimateIncoming = document.documentElement.dataset.sectionNavigationPending === "true";

    document.querySelectorAll<HTMLElement>("[data-section-accordion]").forEach((accordion) => {
      const currentPageId = accordion.dataset.currentPage;
      const panels = accordion.querySelectorAll<PanelElement>("[data-heading-panel]");

      panels.forEach((panel) => {
        const item = panel.closest<HTMLElement>("[data-page-id]");
        const isCurrent = item?.dataset.pageId === currentPageId;
        setPanelOpen(
          panel,
          isCurrent,
          accordion.dataset.accordionReady === "true" || shouldAnimateIncoming,
          shouldAnimateIncoming && isCurrent,
        );
      });

      if (accordion.dataset.accordionReady === "true") {
        return;
      }

      accordion.dataset.accordionReady = "true";

      accordion.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element
          ? target.closest<HTMLAnchorElement>("[data-section-page-link]")
          : null;

        if (!link || link.getAttribute("aria-current") === "page" || event.defaultPrevented) {
          return;
        }

        document.documentElement.dataset.sectionNavigationPending = "true";

        panels.forEach((panel) => {
          if (panel.dataset.open === "true") {
            setPanelOpen(panel, false, true);
          }
        });
      });
    });

    if (shouldAnimateIncoming) {
      delete document.documentElement.dataset.sectionNavigationPending;
    }
  };

  initializeSectionAccordions();

  if (document.documentElement.dataset.sectionAccordionListenerReady !== "true") {
    document.documentElement.dataset.sectionAccordionListenerReady = "true";
    document.addEventListener("astro:page-load", initializeSectionAccordions);
  }
</script>

<style>
  .section-sidebar {
    align-self: start;
    display: grid;
    max-height: calc(100vh - 6rem);
    overflow: auto;
    position: sticky;
    top: 5.5rem;
  }

  nav {
    display: grid;
    gap: 0.25rem;
  }

  .sidebar-title {
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 800;
    margin: 0 0 0.35rem;
    text-transform: uppercase;
  }

  .page-nav-item {
    display: grid;
    gap: 0.125rem;
    min-width: 0;
  }

  a {
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    display: block;
    font-size: 0.94rem;
    font-weight: 600;
    line-height: 1.35;
    padding: 0.45rem 0.6rem;
    text-decoration: none;
  }

  a:hover,
  a[aria-current="page"] {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .page-headings {
    display: grid;
    gap: 0.05rem;
    margin: 0 0 0.45rem 0.95rem;
    min-width: 0;
    overflow: hidden;
    transition: height 180ms ease, opacity 180ms ease;
  }

  .page-headings[data-open="false"] {
    height: 0;
    margin-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  .page-headings[data-open="true"] {
    opacity: 1;
  }

  .heading-link {
    border-radius: calc(var(--radius-sm) * 0.75);
    color: var(--color-muted);
    font-size: 0.84rem;
    font-weight: 600;
    padding: 0.28rem 0.45rem;
  }

  .heading-link:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  @media (max-width: 900px) {
    .section-sidebar {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-headings {
      transition: none;
    }
  }
</style>
